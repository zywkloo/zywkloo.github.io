---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_AUTHOR } from '../../consts';

const docs = (await getCollection('docs')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Docs & Guides | ${SITE_AUTHOR}`}
			description="In-depth guides and case studies on SEO/GEO, web architecture, and shipping open-source dev tools."
			ogImageUrl="/images/blog-og.svg"
		/>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<h1>Docs &amp; Guides</h1>
				<p>深度指南与案例分析 — SEO/GEO、架构选型与开源工具实践。</p>
			</header>
			<ul class="card-list">
				{docs.map((doc) => (
					<li>
						<a href={`/docs/${doc.id}/`}>
							<h2 class="card-title">{doc.data.title}</h2>
							<p class="card-desc">{doc.data.description}</p>
							<p class="card-meta"><FormattedDate date={doc.data.pubDate} /></p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<style>
			main {
				width: min(820px, 100%);
				margin: 0 auto;
				padding: 0 1rem;
			}
			.page-head {
				text-align: center;
				padding: 2.5rem 0 1.5rem;
			}
			.page-head h1 {
				margin: 0 0 0.4rem;
				font-size: 2.4rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			.page-head p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.card-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			.card-list li {
				border: 1px solid var(--line);
				border-radius: 14px;
				background: rgba(255, 255, 255, 0.6);
				transition: 0.2s var(--ease);
			}
			.card-list li:hover {
				box-shadow: var(--shadow-sm);
				transform: translateY(-2px);
			}
			.card-list a {
				display: block;
				padding: 1.2rem 1.4rem;
				text-decoration: none;
				color: inherit;
			}
			.card-title {
				margin: 0 0 0.4rem;
				font-size: 1.2rem;
				line-height: 1.35;
				color: rgb(var(--black));
			}
			.card-desc {
				margin: 0 0 0.5rem;
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}
			.card-meta {
				margin: 0;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.card-list a:hover .card-title {
				color: rgb(var(--accent));
			}
		</style>
	</body>
</html>
