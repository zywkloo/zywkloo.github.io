---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PROFILE_IMAGE, USER_TITLE, GITHUB_URL, WTCRAFT_URL, LINKEDIN_URL, EMAIL } from '../consts';

const MEDIUM_URL = 'https://medium.com/@zywkloo';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="homepage">
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-content">
					<img src={PROFILE_IMAGE} alt="Victor Zhang" class="profile-image" />
					<h1 class="hero-title">Hi, I'm <span class="highlight">Victor Zhang</span></h1>
					<p class="hero-subtitle">{USER_TITLE}</p>
					<p class="hero-subtitle hero-subtitle-secondary">Building end-to-end data systems, from IoT to cloud</p>
					<p class="hero-description">
						I build mobile products where data flows cleanly between devices and backend services. My work spans iOS, React Native, BLE sync, backend data pipelines, and telemetry, with a strong focus on correctness, resilience, and the control policies that keep real systems stable.
					</p>
					<p class="hero-description hero-description-secondary">
						I also spent 5 years as a lead mobile product designer. One of the products I worked on, a basketball game, reached No. 9 in Games and No. 1 in Sports on the Apple App Store (China) on May 3, 2015, where I led core gameplay and monetization design.
					</p>
					<div class="hero-cta">
						<a href="/blog" class="btn btn-primary">View My Blog</a>
						<a href="/about" class="btn btn-secondary">Learn More</a>
					</div>
					<div class="hero-stats">
						<div class="stat">
							<div class="stat-number">10+</div>
							<div class="stat-label">Years in Tech</div>
							<div class="stat-sub">6 in Software Engineering</div>
						</div>
						<div class="stat">
							<div class="stat-number">20+</div>
							<div class="stat-label">Projects</div>
							<div class="stat-sub">#1 Sports in App Store<br />(May 2015, China)</div>
						</div>
						<div class="stat">
							<div class="stat-number">2x</div>
							<div class="stat-label">Hackathon Winner</div>
							<div class="stat-sub">1x University Medal<br />Carleton Uni. 2020</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Expertise Section -->
			<section class="expertise">
				<div class="container">
					<h2 class="section-title">What I Do</h2>
					<div class="expertise-grid">
						<div class="expertise-card">
							<div class="expertise-icon">📱</div>
							<h3>Mobile Development</h3>
							<p>Building production mobile apps across iOS native and React Native, with strong focus on maintainability, performance, and product delivery.</p>
							<ul class="expertise-skills">
								<li>Swift / SwiftUI</li>
								<li>UIKit</li>
								<li>React Native</li>
								<li>Core Data</li>
							</ul>
						</div>
						<div class="expertise-card">
							<div class="expertise-icon">🌐</div>
							<h3>Full Stack Development</h3>
							<p>Building scalable web applications with modern JavaScript frameworks and robust backend services.</p>
							<ul class="expertise-skills">
								<li>React</li>
								<li>Next.js</li>
								<li>Node.js</li>
								<li>FastAPI</li>
							</ul>
						</div>
						<div class="expertise-card">
							<div class="expertise-icon">💻</div>
							<h3>Desktop Development</h3>
							<p>Building and modernizing desktop applications with C#, .NET, C++, and platform-specific UI frameworks.</p>
							<ul class="expertise-skills">
								<li>C#</li>
								<li>.NET Framework</li>
								<li>C++</li>
								<li>macOS (SwiftUI)</li>
							</ul>
						</div>
						<div class="expertise-card">
							<div class="expertise-icon">🎮</div>
							<h3>Game Design</h3>
							<p>Spearheaded core gameplay, engagement loops, and monetization design for a basketball game that reached No. 9 in Games and No. 1 in Sports on the Apple App Store (China).</p>
							<ul class="expertise-skills">
								<li>Gameplay Design</li>
								<li>UI/UX</li>
								<li>Storytelling</li>
								<li>Ranking System</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- Projects Section -->
			<section class="projects">
				<div class="container">
					<h2 class="section-title">Featured Projects</h2>
				<div class="projects-grid">
					<div class="project-card">
						<div class="project-icon">🖌️</div>
						<h3>8 Strokes (永字八法)</h3>
						<p>Metal Ink Engine & On-Device Scoring</p>
						<a href="https://apps.apple.com/ca/app/8strokes/id6774579880" target="_blank" class="project-link">View on App Store →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🌲</div>
						<h3>wtcraft</h3>
						<p>Git-native Multi-Agent Worktree Scaffolding</p>
						<a href="https://github.com/zywkloo/wtcraft" target="_blank" class="project-link">View on GitHub →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🏥</div>
						<h3>VitalMark Wellness</h3>
						<p>HealthKit Integration & SwiftUI</p>
						<a href="https://apps.apple.com/us/app/vitalmark-wellness-fitness/id6745228850" target="_blank" class="project-link">View on App Store →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🤖</div>
						<h3>Ninja AI Agentic App</h3>
						<p>LLM Streaming & Multi-Model AI</p>
						<a href="https://apps.apple.com/us/app/ninja-ai-chat-code-create/id6702030312" target="_blank" class="project-link">View on App Store →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🎬</div>
						<h3>ZZZ Movie Rec System</h3>
						<p>ML-powered Movie Recommendations</p>
						<a href="https://zzz-movie-rec-system.vercel.app/" target="_blank" class="project-link">View Project →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">📚</div>
						<h3>TutorOcean iOS App</h3>
						<p>Professional Tutoring Platform</p>
						<a href="https://apps.apple.com/ca/app/tutorocean/id1480876532" target="_blank" class="project-link">View on App Store →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🔍</div>
						<h3>cuHacking 2020 Winner</h3>
						<p>Crime Scene Forensic Analyzer</p>
						<a href="https://devpost.com/software/murder-on-2nd-floor-web-forensic-analyzer" target="_blank" class="project-link">View on Devpost →</a>
					</div>
					<div class="project-card">
						<div class="project-icon">🏆</div>
						<h3>cuHacking 2019 Winner</h3>
						<p>Amazon Connect Pizza Order System</p>
						<a href="https://devpost.com/software/cuhackingamazonconnect" target="_blank" class="project-link">View on Devpost →</a>
					</div>
				</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section class="contact">
				<div class="container">
					<h2 class="section-title">Let's Connect</h2>
					<p class="contact-text">Interested in collaborating or just want to chat? I'd love to hear from you!</p>
					<div class="contact-buttons">
						<a href={`mailto:${EMAIL}`} class="btn btn-primary">Email Me</a>
						<a href={GITHUB_URL} target="_blank" class="btn btn-secondary">GitHub</a>
						<a href={WTCRAFT_URL} target="_blank" class="btn btn-secondary">wtcraft</a>
						<a href={LINKEDIN_URL} target="_blank" class="btn btn-secondary">LinkedIn</a>
						<a href={MEDIUM_URL} target="_blank" class="btn btn-secondary">Medium</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.homepage {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}

	/* Hero */
	.hero {
		position: relative;
		overflow: hidden;
		padding: clamp(4rem, 11vw, 8rem) 1.5rem clamp(3.5rem, 8vw, 6rem);
		background:
			radial-gradient(720px 420px at 50% -10%, var(--accent-soft) 0%, rgba(227, 244, 239, 0) 70%);
	}

	.hero::after {
		content: '';
		position: absolute;
		inset: auto 0 0 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--line), transparent);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
		max-width: 760px;
		margin: 0 auto;
	}

	.profile-image {
		width: 132px;
		height: 132px;
		border-radius: 50%;
		object-fit: cover;
		border: 4px solid var(--surface-raised);
		box-shadow: 0 0 0 1px var(--line), var(--shadow-lg);
		margin: 0 auto 1.75rem;
		display: block;
		transition: transform var(--dur) var(--ease);
	}
	.profile-image:hover {
		transform: scale(1.04);
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 3.6rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 0.6rem;
		color: rgb(var(--black));
	}
	.highlight {
		background: linear-gradient(120deg, var(--accent) 0%, var(--accent-bright) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: 1.3rem;
		margin: 0 0 0.2rem;
		font-weight: 700;
		color: var(--accent-dark);
	}
	.hero-subtitle-secondary {
		font-size: 1rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: rgb(var(--gray));
		margin-bottom: 1.5rem;
	}

	.hero-description {
		font-size: 1.075rem;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
		max-width: 660px;
		margin: 0 auto 1.1rem;
	}
	.hero-description-secondary {
		font-size: 1rem;
		color: rgb(var(--gray));
		margin-bottom: 1.75rem;
	}

	.hero-cta {
		display: flex;
		gap: 0.85rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 3rem;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		max-width: 560px;
		margin: 0 auto;
	}
	.stat {
		background: var(--surface-raised);
		padding: 1.4rem 1rem;
		border-radius: var(--radius);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-sm);
		transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
	}
	.stat:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}
	.stat-number {
		font-size: 2rem;
		font-weight: 700;
		color: var(--accent-dark);
		letter-spacing: -0.02em;
	}
	.stat-label {
		font-size: 0.74rem;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 700;
		margin-top: 0.25rem;
	}
	.stat-sub {
		margin-top: 0.55rem;
		padding-top: 0.5rem;
		border-top: 1px dashed var(--line);
		font-size: 0.78rem;
		color: rgb(var(--gray));
		font-weight: 600;
	}

	/* Sections */
	section {
		padding: var(--space-section) 0;
	}
	.expertise {
		background: var(--surface-muted);
		border-bottom: 1px solid var(--line);
	}
	.expertise,
	.projects {
		border-top: 1px solid transparent;
	}
	.container {
		max-width: var(--content);
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.section-title {
		text-align: center;
		font-size: clamp(1.9rem, 3.6vw, 2.5rem);
		margin: 0 0 3.25rem;
		position: relative;
		padding-bottom: 1rem;
	}
	.section-title::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 52px;
		height: 3px;
		border-radius: 999px;
		background: var(--accent);
	}

	/* Cards */
	.expertise-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}
	@media (min-width: 700px) {
		.expertise-grid,
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1000px) {
		.expertise-grid {
			grid-template-columns: repeat(4, 1fr);
		}
		.projects-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.expertise-card,
	.project-card {
		background: var(--surface-raised);
		padding: 2rem 1.75rem;
		border-radius: var(--radius-lg);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.3s var(--ease),
			box-shadow 0.3s var(--ease),
			border-color 0.3s var(--ease);
	}
	.expertise-card:hover,
	.project-card:hover {
		transform: translateY(-6px);
		box-shadow: var(--shadow-lg);
		border-color: rgba(var(--accent-rgb), 0.32);
	}

	.expertise-icon,
	.project-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.25rem;
		height: 3.25rem;
		font-size: 1.6rem;
		border-radius: 14px;
		background: var(--accent-soft);
		margin-bottom: 1.25rem;
	}

	.expertise-card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.6rem;
		color: rgb(var(--black));
	}
	.expertise-card p {
		color: rgb(var(--gray));
		font-size: 0.96rem;
		line-height: 1.65;
		margin-bottom: 1.35rem;
	}
	.expertise-skills {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}
	.expertise-skills li {
		background: var(--surface-muted);
		border: 1px solid var(--line);
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		font-size: 0.8rem;
		color: var(--accent-dark);
		font-weight: 700;
	}

	.project-card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.35rem;
		color: rgb(var(--black));
	}
	.project-card p {
		color: rgb(var(--gray));
		font-size: 0.95rem;
		margin-bottom: 1.1rem;
	}
	.project-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--accent);
		font-weight: 700;
		font-size: 0.92rem;
		transition: gap 0.2s var(--ease), color 0.2s var(--ease);
	}
	.project-link:hover {
		color: var(--accent-dark);
		gap: 0.6rem;
	}

	/* Contact */
	.contact {
		background:
			radial-gradient(620px 320px at 80% 0%, var(--on-dark-glow) 0%, transparent 60%),
			var(--surface-deep);
		color: rgba(255, 255, 255, 0.86);
		position: relative;
	}
	.contact .section-title {
		color: #fff;
	}
	.contact .section-title::after {
		background: var(--on-dark-accent);
	}
	.contact-text {
		text-align: center;
		font-size: 1.08rem;
		max-width: 540px;
		margin: 0 auto 2.25rem;
		color: rgba(255, 255, 255, 0.72);
	}
	.contact-buttons {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.contact .btn-primary {
		background: var(--on-dark-accent);
		color: var(--on-dark-accent-text);
		box-shadow: 0 14px 34px rgba(0, 0, 0, 0.4);
	}
	.contact .btn-primary:hover {
		background: #f4f4f5;
		color: var(--on-dark-accent-text);
		transform: translateY(-2px);
	}
	.contact .btn-secondary {
		background: rgba(255, 255, 255, 0.06);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.22);
		box-shadow: none;
	}
	.contact .btn-secondary:hover {
		background: rgba(255, 255, 255, 0.13);
		color: #fff;
		border-color: rgba(255, 255, 255, 0.4);
		transform: translateY(-2px);
	}

	@media (max-width: 720px) {
		.hero-stats {
			grid-template-columns: 1fr;
			max-width: 320px;
		}
	}
</style>
