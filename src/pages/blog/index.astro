---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_AUTHOR, seriesBadgeClass, seriesBadgeLabel, SERIES_META, getSeriesMeta } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Compute counts
const seriesCounts = new Map<string, number>();
let otherCount = 0;
const allCount = posts.length;

posts.forEach(post => {
	const meta = getSeriesMeta(post.data.series);
	if (meta) {
		seriesCounts.set(meta.key, (seriesCounts.get(meta.key) || 0) + 1);
	} else {
		otherCount++;
	}
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Blog | ${SITE_AUTHOR}`}
			description={SITE_DESCRIPTION}
			ogImageUrl="/images/blog-og.svg"
		/>
		<style>
			main {
				width: 1000px;
				max-width: 100%;
				margin: 0 auto;
			}
			.blog-container {
				display: flex;
				gap: 2rem;
				align-items: flex-start;
			}
			.sidebar {
				width: 90px;
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				overflow: hidden;
				position: sticky;
				top: 2rem;
				background: rgba(var(--gray-light), 0.2);
				padding: 1rem 0;
				border-radius: 16px;
				border: 1px solid rgba(var(--gray), 0.1);
			}
			.sidebar:hover {
				width: 320px;
				background: rgba(var(--gray-light), 0.5);
			}
			.filter-btn {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.6rem 1rem;
				border: none;
				background: transparent;
				cursor: pointer;
				transition: background 0.2s;
				text-align: left;
				white-space: nowrap;
				color: rgb(var(--black));
				font-family: inherit;
				font-size: 0.95rem;
			}
			.filter-btn:hover {
				background: rgba(var(--gray), 0.1);
			}
			.filter-btn.active {
				background: rgba(var(--gray), 0.15);
				font-weight: 600;
			}
			.filter-icon {
				font-size: 1.3rem;
				width: 28px;
				text-align: center;
				flex-shrink: 0;
			}
			.filter-short {
				display: inline-block;
				opacity: 1;
				transition: opacity 0.2s;
				color: rgb(var(--gray-dark));
			}
			.filter-full {
				display: none;
				opacity: 0;
				transition: opacity 0.2s;
			}
			.sidebar:hover .filter-short {
				display: none;
				opacity: 0;
			}
			.sidebar:hover .filter-full {
				display: inline-block;
				opacity: 1;
			}
			.content {
				flex-grow: 1;
				min-width: 0;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li.featured-post {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li.featured-post .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				height: 220px;
				object-fit: cover;
				object-position: center;
			}
			ul li.featured-post img {
				height: auto;
				max-height: 520px;
				object-position: top;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.series-badge-container {
				margin-top: 0.75rem;
				margin-bottom: 0.35rem;
			}
			.series-badge {
				display: inline-block;
				padding: 0.15rem 0.55rem;
				font-size: 0.72rem;
				font-weight: 700;
				border-radius: 9999px;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.series-badge.tokenchef {
				background-color: rgba(239, 68, 68, 0.08);
				color: #ef4444;
				border: 1px solid rgba(239, 68, 68, 0.18);
			}
			.series-badge.metalsolo {
				background-color: rgba(139, 92, 246, 0.08);
				color: #8b5cf6;
				border: 1px solid rgba(139, 92, 246, 0.18);
			}
			.series-badge.cleansemantics {
				background-color: rgba(14, 165, 233, 0.08);
				color: #0ea5e9;
				border: 1px solid rgba(14, 165, 233, 0.18);
			}
			.series-badge.reactnativeculprits {
				background-color: rgba(97, 218, 251, 0.08);
				color: #0c8ba8;
				border: 1px solid rgba(97, 218, 251, 0.2);
			}
			.meta {
				margin: 0;
				color: rgb(var(--gray));
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				align-items: center;
				font-size: 0.95rem;
				justify-content: flex-start;
			}
			ul li.featured-post .meta {
				justify-content: center;
			}
			.meta-separator {
				opacity: 0.6;
			}
			.meta-stats {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
			}
			.views {
				font-variant-numeric: tabular-nums;
			}
			ul li a:hover h4,
			ul li a:hover .meta {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 768px) {
				.blog-container {
					flex-direction: column;
				}
				.sidebar {
					width: 100%;
					flex-direction: row;
					flex-wrap: wrap;
					position: static;
					padding: 0.5rem;
					border-radius: 8px;
				}
				.sidebar:hover {
					width: 100%;
				}
				.filter-btn {
					padding: 0.4rem 0.8rem;
				}
				.filter-short {
					display: none;
				}
				.filter-full {
					display: inline-block;
					opacity: 1;
				}
				ul {
					gap: 1.1rem;
				}
				ul li {
					width: 100%;
					text-align: left;
				}
				ul li.featured-post {
					margin-bottom: 0;
					text-align: left;
				}
				ul li.featured-post .meta {
					justify-content: flex-start;
				}
				ul li img,
				ul li.featured-post img {
					height: auto;
					aspect-ratio: 16 / 9;
					object-fit: cover;
				}
				ul li .title,
				ul li.featured-post .title {
					font-size: 1.45rem;
					line-height: 1.2;
				}
				.meta {
					font-size: 0.9rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-container">
				<aside class="sidebar" id="blog-sidebar">
					<button class="filter-btn active" data-series="all">
						<span class="filter-icon">📚</span>
						<span class="filter-short">All</span>
						<span class="filter-full">All Posts ({allCount})</span>
					</button>
					{Object.entries(SERIES_META).map(([key, meta]) => {
						const count = seriesCounts.get(key) || 0;
						if (count === 0) return null;
						return (
							<button class="filter-btn" data-series={key}>
								<span class="filter-icon">{meta.icon}</span>
								<span class="filter-short">{meta.shortName}</span>
								<span class="filter-full">{meta.name} ({count})</span>
							</button>
						);
					})}
					{otherCount > 0 && (
						<button class="filter-btn" data-series="other">
							<span class="filter-icon">📝</span>
							<span class="filter-short">Other</span>
							<span class="filter-full">Other ({otherCount})</span>
						</button>
					)}
				</aside>
				<section class="content">
					<ul id="blog-list">
						{
							posts.map((post) => {
								const meta = getSeriesMeta(post.data.series);
								const seriesKey = meta ? meta.key : 'other';
								return (
									<li data-series-key={seriesKey}>
										<a href={`/blog/${post.id}/`}>
											{post.data.heroImage && (
												<Image width={720} height={360} src={post.data.heroImage} alt="" />
											)}
											{post.data.series && (
												<div class="series-badge-container">
													<span class={`series-badge ${seriesBadgeClass(post.data.series)}`}>
														{seriesBadgeLabel(post.data.series)}
													</span>
												</div>
											)}
											<h4 class="title" set:html={post.data.title.split(' / ')[0]}></h4>
											<p class="meta">
												<FormattedDate date={post.data.pubDate} />
												<span class="meta-stats" data-post-card-stats hidden>
													<span class="meta-separator">·</span>
													<span class="views" data-post-card-view data-slug={post.id}>
														<span data-post-card-view-value>--</span> views
													</span>
												</span>
											</p>
										</a>
									</li>
								);
							})
						}
					</ul>
				</section>
			</div>
		</main>
		<script>
			import { fetchViewCounts, hasPostStatsConfig } from '../../lib/post-stats';

			const formatViews = (count: number) => new Intl.NumberFormat('en-US').format(count);

			const viewNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-post-card-view]'));

			if (!hasPostStatsConfig()) {
				viewNodes.forEach((node) => {
					node.closest('[data-post-card-stats]')?.setAttribute('hidden', '');
				});
			} else {
				const slugs = viewNodes
					.map((node) => node.dataset.slug)
					.filter((slug) => typeof slug === 'string');

				void fetchViewCounts(slugs).then((counts) => {
					if (!counts) {
						viewNodes.forEach((node) => {
							node.closest('[data-post-card-stats]')?.setAttribute('hidden', '');
						});
						return;
					}

					viewNodes.forEach((node) => {
						const slug = node.dataset.slug;
						const valueNode = node.querySelector('[data-post-card-view-value]');
						if (!slug || !valueNode) {
							node.closest('[data-post-card-stats]')?.setAttribute('hidden', '');
							return;
						}

						valueNode.textContent = formatViews(counts.get(slug) ?? 0);
						node.closest('[data-post-card-stats]')?.removeAttribute('hidden');
					});
				});
			}

			// Sidebar Filtering Logic
			const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
			const blogItems = document.querySelectorAll<HTMLLIElement>('#blog-list li');
			
			function updateFeatured() {
				let firstVisible = true;
				blogItems.forEach(item => {
					item.classList.remove('featured-post');
					if (item.style.display !== 'none' && firstVisible) {
						item.classList.add('featured-post');
						firstVisible = false;
					}
				});
			}
			
			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					filterBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					
					const series = btn.dataset.series;
					blogItems.forEach(item => {
						if (series === 'all' || item.dataset.seriesKey === series) {
							item.style.display = '';
						} else {
							item.style.display = 'none';
						}
					});
					updateFeatured();
				});
			});
			updateFeatured();
		</script>
		<Footer />
	</body>
</html>
