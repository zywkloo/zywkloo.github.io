---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostViewCount from '../components/PostViewCount.astro';

interface Props {
	title: string;
	description: string;
	series?: string;
	slug?: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
}

const { title, description, series, slug, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				position: relative;
				overflow: hidden;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				height: auto;
			}
			.hero-overlay {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0.3) 0%,
					rgba(0, 0, 0, 0.1) 40%,
					rgba(0, 0, 0, 0) 60%,
					rgba(0, 0, 0, 0.1) 80%,
					rgba(0, 0, 0, 0.3) 100%
				);
				pointer-events: none;
				border-radius: 12px;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.prose :global(h2) {
				font-size: 1.55em;
				margin-top: 1.9em;
				margin-bottom: 0.6em;
				line-height: 1.3;
			}
			.prose :global(h3) {
				font-size: 1.25em;
				margin-top: 1.4em;
				margin-bottom: 0.45em;
				line-height: 1.35;
			}
			.prose :global(p) {
				margin-bottom: 1em;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0 0 1.35em 0.4em;
				padding-left: 1.6em;
			}
			.prose :global(ul) {
				list-style: disc outside;
			}
			.prose :global(ol) {
				list-style: decimal outside;
			}
			.prose :global(li) {
				margin-bottom: 0.5em;
				padding-left: 0.25em;
			}
			.prose :global(li)::marker {
				color: var(--accent-dark);
				font-weight: 700;
			}
			.prose :global(img) {
				margin: 1.4em 0;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose :global(table) {
				width: 100%;
				table-layout: fixed;
				border-collapse: collapse;
				margin: 1.25em 0 1.75em;
			}
			.prose :global(table th),
			.prose :global(table td) {
				width: 50%;
				padding: 0.6rem;
				vertical-align: top;
				text-align: center;
			}
			.prose :global(table td img) {
				width: 100%;
				height: 420px;
				object-fit: contain;
				object-position: center;
				margin: 0;
				background: rgb(var(--gray-light));
			}
			.prose :global(blockquote) {
				margin: 1.2em 0;
				font-size: 1.05em;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.series {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				margin-bottom: 0.9em;
				padding: 0.45em 0.85em;
				border: 1px solid rgba(var(--accent), 0.18);
				border-radius: 999px;
				background: rgba(var(--accent), 0.08);
				color: var(--accent-dark);
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				line-height: 1;
				text-transform: uppercase;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.1em;
				line-height: 1.2;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				.title h1 {
					font-size: 1.7em;
				}
				.prose :global(h2) {
					font-size: 1.35em;
				}
				.prose :global(h3) {
					font-size: 1.15em;
				}
				.prose :global(table td img) {
					height: 280px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
					<div class="hero-overlay"></div>
				</div>
				<div class="prose">
					<div class="title">
						{series && <div class="series">{series}</div>}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{slug && <PostViewCount slug={slug} />}
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
